modules = ["nodejs-20", "web", "postgresql-16"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd restaurant-backend && npm run dev:server"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd restaurant-backend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[userenv]

[userenv.shared]
MAIL_FROM = "Restaurant <rudhransaiccs428@gmail.com>"
MAIL_SMTP_HOST = "smtp.gmail.com"
MAIL_SMTP_PORT = "587"
MAIL_SMTP_USER = "rudhransaiccs428@gmail.com"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd restaurant-backend && npm run start:server"]
build = ["sh", "-c", "cd restaurant-backend && npm install && npm run build"]
