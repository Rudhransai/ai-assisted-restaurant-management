# ── Database ────────────────────────────────────────────────────────────────
# Local PostgreSQL:  postgres://postgres:yourpassword@localhost:5432/restaurant
# Free cloud DB:     https://neon.tech  or  https://supabase.com
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/restaurant

# SSL is auto-enabled for remote/cloud databases and disabled for localhost.
# Override only if needed (e.g. a local server that requires SSL):
# DATABASE_SSL=true

# ── Auth ────────────────────────────────────────────────────────────────────
# Any long random string used to sign login (JWT) tokens.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an App Password for "Mail"
# 3. Paste it in MAIL_SMTP_PASS (no spaces)
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your_gmail@gmail.com
MAIL_SMTP_PASS=your_16_char_app_password
MAIL_FROM="Restaurant <your_gmail@gmail.com>"
